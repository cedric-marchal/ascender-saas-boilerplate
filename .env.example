# Global Environment Variables

NEXT_PUBLIC_APP_NAME="Next SaaS Boilerplate"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_VERCEL_MAX_UPLOAD_SIZE="4718592" # 4.5MB

MAINTENANCE_ENABLED="false"

NEXT_TELEMETRY_DISABLED=1

# BetterAuth

BETTER_AUTH_SECRET="" # 32 characters required

# Google

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Upstash

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Prisma

DATABASE_URL=""

# Cloudflare R2

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

R2_BUCKET_NAME=""
NEXT_PUBLIC_R2_PUBLIC_URL=""

# Resend

RESEND_API_KEY=""

RESEND_EMAIL_NOREPLY="noreply@tonapp.dev"
RESEND_EMAIL_CONTACT="contact@tonapp.dev"
RESEND_EMAIL_SECURITY="security@tonapp.dev"

# Stripe

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# One STRIPE_PRICE_ID_* var per plan in PLAN_CONFIG (features/billing/constants/plan.constant.ts).
# Adding a plan = one new var here + one new entry in PLAN_CONFIG, no other code change.
STRIPE_PRICE_ID_PRO=""

# Observability (optional)
#
# All of these are optional — the app boots normally when they are absent.
# Setting them activates NOTHING by itself: `@sentry/nextjs` and
# `posthog-js`/`posthog-node` are not installed yet. See
# docs/OBSERVABILITY.md for the exact remaining steps to wire Sentry error
# tracking and PostHog product analytics.

SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
